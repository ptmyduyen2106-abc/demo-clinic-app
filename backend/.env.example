# ──────────────────────────────────────────────────────────
# clinic-app/backend/.env
# Copy file này thành .env rồi điền giá trị thực
# ──────────────────────────────────────────────────────────

# Port server lắng nghe
PORT=8080

# Supabase Project URL
# Lấy từ: Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://pvmylmgywyyzuptnbwup.supabase.co

# Service Role Key (backend only — KHÔNG expose ra frontend)
# Lấy từ: Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret (dùng để verify Supabase access token từ client)
# Lấy từ: Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-here
